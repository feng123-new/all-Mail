# Copy this file to oauth-temp/config.env and fill in your own values.
CLIENT_ID=9e9235c0-a182-44f9-80b5-6e3fbd9c3229
CLIENT_SECRET=replace-with-your-client-secret
REDIRECT_URI=http://localhost:8765/callback

# Optional overrides
TENANT=consumers
SCOPES=offline_access openid profile email https://graph.microsoft.com/User.Read https://graph.microsoft.com/Mail.ReadWrite https://graph.microsoft.com/Mail.Send https://outlook.office.com/IMAP.AccessAsUser.All https://graph.microsoft.com/Contacts.Read https://graph.microsoft.com/Contacts.ReadWrite https://graph.microsoft.com/Calendars.Read https://graph.microsoft.com/Calendars.ReadWrite https://graph.microsoft.com/MailboxSettings.Read https://graph.microsoft.com/MailboxSettings.ReadWrite
SEPARATOR=----
# If id_token does not contain email, set it manually.
ACCOUNT_EMAIL=

# Optional: direct update of an existing all-Mail mailbox after OAuth
ADMIN_BASE_URL=http://127.0.0.1:3002
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-your-admin-password
# Optional preferred target ID. Safe behavior:
# - same email -> update
# - different email -> create new instead of overwrite
TARGET_EMAIL_ID=5
# Set true ONLY if you intentionally want to replace TARGET_EMAIL_ID with a different email.
ALLOW_TARGET_ID_REPLACE=false
