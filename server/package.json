{
    "name": "all-mail-server",
    "version": "2.0.0",
    "description": "all-Mail Server - Fastify + TypeScript + Prisma",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "npm run dev:api",
        "dev:api": "tsx watch src/index.ts",
        "dev:jobs": "tsx watch src/worker.ts",
        "build": "tsc -p tsconfig.build.json",
        "lint": "eslint \"src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "test": "node --test --test-force-exit --import tsx src/**/*.test.ts",
        "start": "npm run start:api",
        "start:api": "node dist/index.js",
        "start:jobs": "node dist/worker.js",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:repair:legacy-p3005": "prisma db execute --file prisma/legacy-p3005-repair.sql --schema prisma/schema.prisma",
        "db:migrate": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "ingress:ensure": "tsx scripts/ensure-ingress-endpoint.ts",
        "ingress:check": "tsx scripts/ensure-ingress-endpoint.ts --check"
    },
    "dependencies": {
        "@fastify/cookie": "^11.0.1",
        "@fastify/cors": "^10.0.1",
        "@fastify/helmet": "^12.0.1",
        "@fastify/rate-limit": "^10.2.0",
        "@fastify/static": "^8.0.3",
        "@fastify/swagger": "^9.4.2",
        "@fastify/swagger-ui": "^5.2.1",
        "@prisma/client": "^6.19.2",
        "bcryptjs": "^2.4.3",
        "dotenv": "^16.4.7",
        "fastify": "^5.8.4",
        "fastify-plugin": "^5.1.0",
        "ioredis": "^5.4.2",
        "jose": "^5.9.6",
        "mailparser": "^3.9.6",
        "node-imap": "^0.9.6",
        "nodemailer": "^8.0.4",
        "pino": "^9.6.0",
        "pino-pretty": "^13.0.0",
        "prisma": "^6.19.2",
        "resend": "^6.9.4",
        "undici": "^7.24.5",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/mailparser": "^3.4.5",
        "@types/node": "^22.10.2",
        "@types/node-imap": "^0.9.3",
        "@types/nodemailer": "^7.0.11",
        "eslint": "^9.39.1",
        "globals": "^16.5.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.46.4"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "overrides": {
        "brace-expansion": "5.0.5",
        "defu": "6.1.6",
        "effect": "3.21.0",
        "yaml": "2.8.3",
        "utf7": {
            "semver": "5.7.2"
        }
    }
}
