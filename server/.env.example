# Advanced source / CLI runtime template.
#
# Default Docker deployments should use the root `.env.example` or
# `.env.cloudflare.example` instead. Use this file only when you intentionally
# run the compiled server outside the main Docker app container.

# Server
NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Redis (optional)
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=
ALLOW_LOCAL_RATE_LIMIT_FALLBACK=false

# Security / bootstrap secrets
# Leave these blank if you want the Docker/npm bootstrap path to generate and persist them automatically.
# - JWT_SECRET: signs admin/mailbox-portal login tokens
# - ENCRYPTION_KEY: encrypts stored mailbox passwords, OAuth secrets, and refresh tokens
# - ADMIN_PASSWORD: bootstrap admin password for the first console login; auto-generated if blank
JWT_SECRET=
JWT_EXPIRES_IN=2h
ENCRYPTION_KEY=

# Bootstrap admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
DOMAIN_BOOTSTRAP_ADMIN_USERNAME=admin
DOMAIN_BOOTSTRAP_ADMIN_PASSWORD=
SEND_ENABLED_DOMAINS=

# Login protection
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCK_MINUTES=15
ADMIN_2FA_SECRET=
ADMIN_2FA_WINDOW=1
API_LOG_RETENTION_DAYS=30
API_LOG_CLEANUP_INTERVAL_MINUTES=60
FORWARDING_WORKER_INTERVAL_SECONDS=30
FORWARDING_WORKER_BATCH_SIZE=10

# Ingress/runtime extras
# Do not keep the shipped placeholder value in a real deployment.
INGRESS_SIGNING_SECRET=
INGRESS_ALLOWED_SKEW_SECONDS=300

# Optional provider OAuth (provider-side credentials, not required for app startup)
# Replace 127.0.0.1 below with your cloud server public IP/domain or the correct local address.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/admin/oauth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.modify https://mail.google.com/
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/admin/oauth/outlook/callback
MICROSOFT_OAUTH_TENANT=consumers
MICROSOFT_OAUTH_SCOPES=offline_access openid profile email https://graph.microsoft.com/User.Read https://graph.microsoft.com/Mail.ReadWrite https://graph.microsoft.com/Mail.Send https://graph.microsoft.com/Contacts.ReadWrite https://graph.microsoft.com/Calendars.ReadWrite https://graph.microsoft.com/MailboxSettings.ReadWrite
