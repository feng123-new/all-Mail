generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 管理员
// ============================================
model Admin {
  id           Int       @id @default(autoincrement())
  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  email        String?   @unique @db.VarChar(100)
  role         Role      @default(ADMIN)
  status       Status    @default(ACTIVE)
  mustChangePassword Boolean @default(false) @map("must_change_password")
  twoFactorEnabled    Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret     String?   @map("two_factor_secret") @db.Text
  twoFactorTempSecret String?   @map("two_factor_temp_secret") @db.Text
  lastLoginAt  DateTime? @map("last_login_at")
  lastLoginIp  String?   @map("last_login_ip") @db.VarChar(45)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  apiKeys ApiKey[]
  domains Domain[] @relation("AdminCreatedDomains")

  @@map("admins")
}

// ============================================
// API Key
// ============================================
model ApiKey {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  keyHash     String    @unique @map("key_hash") @db.VarChar(64)
  keyPrefix   String    @map("key_prefix") @db.VarChar(8)
  permissions Json?
  allowedGroupIds Json? @map("allowed_group_ids")
  allowedEmailIds Json? @map("allowed_email_ids")
  allowedDomainIds Json? @map("allowed_domain_ids")
  rateLimit   Int       @default(60) @map("rate_limit")
  status      Status    @default(ACTIVE)
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  usageCount  BigInt    @default(0) @map("usage_count")
  createdBy   Int       @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  creator     Admin        @relation(fields: [createdBy], references: [id])
  emailUsages EmailUsage[]
  domainMailboxUsages DomainMailboxUsage[]
  apiLogs     ApiLog[]

  @@map("api_keys")
}

model ProviderOAuthConfig {
  id           Int          @id @default(autoincrement())
  provider     MailProvider @unique
  clientId     String?      @map("client_id") @db.VarChar(255)
  clientSecret String?      @map("client_secret") @db.Text
  redirectUri  String?      @map("redirect_uri") @db.Text
  scopes       String?      @db.Text
  tenant       String?      @db.VarChar(100)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@map("provider_oauth_configs")
}

// ============================================
// 邮箱分组
// ============================================
model EmailGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  fetchStrategy MailFetchStrategy @default(GRAPH_FIRST) @map("fetch_strategy")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  emails EmailAccount[]

  @@map("email_groups")
}

// ============================================
// 邮箱账户
// ============================================
model EmailAccount {
  id             Int          @id @default(autoincrement())
  email          String       @unique @db.VarChar(255)
  provider       MailProvider @default(OUTLOOK)
  authType       MailAuthType @default(MICROSOFT_OAUTH) @map("auth_type")
  providerConfig Json?        @map("provider_config")
  capabilities   Json?
  clientId       String?      @map("client_id") @db.VarChar(255)
  password       String?      @db.VarChar(255)
  accountLoginPassword String? @map("account_login_password") @db.VarChar(255)
  refreshToken   String?      @map("refresh_token") @db.Text
  clientSecret   String?      @map("client_secret") @db.Text
  status         EmailStatus  @default(ACTIVE)
  groupId        Int?         @map("group_id")
  lastCheckAt    DateTime?    @map("last_check_at")
  mailboxStatus  Json?        @map("mailbox_status")
  errorMessage   String?      @map("error_message") @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  group   EmailGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  usages  EmailUsage[]
  apiLogs ApiLog[]

  @@index([provider])
  @@index([authType])
  @@map("email_accounts")
}

// ============================================
// 邮箱使用记录（邮箱池）
// ============================================
model EmailUsage {
  id             Int      @id @default(autoincrement())
  apiKeyId       Int      @map("api_key_id")
  emailAccountId Int      @map("email_account_id")
  usedAt         DateTime @default(now()) @map("used_at")

  apiKey       ApiKey       @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  emailAccount EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, emailAccountId])
  @@map("email_usage")
}

// ============================================
// API 调用日志
// ============================================
model ApiLog {
  id             BigInt    @id @default(autoincrement())
  apiKeyId       Int?      @map("api_key_id")
  emailAccountId Int?      @map("email_account_id")
  action         String    @db.VarChar(50)
  requestIp      String?   @map("request_ip") @db.VarChar(45)
  responseCode   Int?      @map("response_code")
  responseTimeMs Int?      @map("response_time_ms")
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")

  apiKey       ApiKey?       @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  emailAccount EmailAccount? @relation(fields: [emailAccountId], references: [id], onDelete: SetNull)

  @@index([apiKeyId])
  @@index([emailAccountId])
  @@index([createdAt])
  @@index([action, createdAt])
  @@map("api_logs")
}

model Domain {
  id                     Int           @id @default(autoincrement())
  name                   String        @unique @db.VarChar(255)
  displayName            String?       @map("display_name") @db.VarChar(255)
  status                 DomainStatus  @default(PENDING)
  provider               String        @default("CLOUDFLARE") @db.VarChar(50)
  canReceive             Boolean       @default(true) @map("can_receive")
  canSend                Boolean       @default(false) @map("can_send")
  isCatchAllEnabled      Boolean       @default(false) @map("is_catch_all_enabled")
  catchAllTargetMailboxId Int?         @map("catch_all_target_mailbox_id")
  verificationToken      String?       @map("verification_token") @db.VarChar(255)
  dnsStatus              Json?         @map("dns_status")
  resendDomainId         String?       @map("resend_domain_id") @db.VarChar(255)
  createdByAdminId       Int           @map("created_by_admin_id")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  creator          Admin                 @relation("AdminCreatedDomains", fields: [createdByAdminId], references: [id])
  mailboxes        DomainMailbox[]
  aliases          MailboxAlias[]
  inboundMessages  InboundMessage[]
  outboundMessages OutboundMessage[]
  sendingConfigs   DomainSendingConfig[]
  ingressEndpoints IngressEndpoint[]

  @@index([status])
  @@map("domains")
}

model DomainSendingConfig {
  id              Int          @id @default(autoincrement())
  domainId        Int          @map("domain_id")
  provider        SendProvider @default(RESEND)
  apiKeyEncrypted String       @map("api_key_encrypted") @db.Text
  fromNameDefault String?      @map("from_name_default") @db.VarChar(255)
  replyToDefault  String?      @map("reply_to_default") @db.VarChar(255)
  status          Status       @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([domainId, provider])
  @@map("domain_sending_configs")
}

model MailboxUser {
  id                 Int               @id @default(autoincrement())
  username           String            @unique @db.VarChar(100)
  email              String?           @unique @db.VarChar(255)
  passwordHash       String            @map("password_hash") @db.VarChar(255)
  status             MailboxUserStatus @default(ACTIVE)
  twoFactorEnabled   Boolean           @default(false) @map("two_factor_enabled")
  twoFactorSecret    String?           @map("two_factor_secret") @db.Text
  mustChangePassword Boolean           @default(true) @map("must_change_password")
  lastLoginAt        DateTime?         @map("last_login_at")
  lastLoginIp        String?           @map("last_login_ip") @db.VarChar(45)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  memberships  MailboxMembership[]
  ownedMailboxes DomainMailbox[] @relation("MailboxOwner")

  @@map("mailbox_users")
}

model DomainMailbox {
  id               Int                 @id @default(autoincrement())
  domainId         Int                 @map("domain_id")
  localPart        String              @map("local_part") @db.VarChar(255)
  address          String              @unique @db.VarChar(255)
  displayName      String?             @map("display_name") @db.VarChar(255)
  status           DomainMailboxStatus @default(ACTIVE)
  provisioningMode DomainMailboxProvisioningMode @default(MANUAL) @map("provisioning_mode")
  batchTag         String?             @map("batch_tag") @db.VarChar(100)
  quotaMb          Int?                @map("quota_mb")
  passwordHash     String?             @map("password_hash") @db.VarChar(255)
  canLogin         Boolean             @default(true) @map("can_login")
  isCatchAllTarget Boolean             @default(false) @map("is_catch_all_target")
  ownerUserId      Int?                @map("owner_user_id")
  forwardMode      ForwardMode         @default(DISABLED) @map("forward_mode")
  forwardTo        String?             @map("forward_to") @db.VarChar(255)
  metadata         Json?
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  domain           Domain              @relation(fields: [domainId], references: [id], onDelete: Cascade)
  ownerUser        MailboxUser?        @relation("MailboxOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  memberships      MailboxMembership[]
  aliases          MailboxAlias[]
  usages           DomainMailboxUsage[]
  inboundMessages  InboundMessage[]
  forwardJobs      MailboxForwardJob[]
  outboundMessages OutboundMessage[]

  @@unique([domainId, localPart])
  @@index([ownerUserId])
  @@index([domainId, provisioningMode])
  @@index([domainId, batchTag])
  @@map("domain_mailboxes")
}

model DomainMailboxUsage {
  id              Int      @id @default(autoincrement())
  apiKeyId        Int      @map("api_key_id")
  domainMailboxId Int      @map("domain_mailbox_id")
  usedAt          DateTime @default(now()) @map("used_at")

  apiKey        ApiKey        @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  domainMailbox DomainMailbox @relation(fields: [domainMailboxId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, domainMailboxId])
  @@map("domain_mailbox_usage")
}

model MailboxMembership {
  id        Int         @id @default(autoincrement())
  mailboxId Int         @map("mailbox_id")
  userId    Int         @map("user_id")
  role      MailboxRole @default(MEMBER)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  mailbox DomainMailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  user    MailboxUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mailboxId, userId])
  @@map("mailbox_memberships")
}

model MailboxAlias {
  id            Int      @id @default(autoincrement())
  mailboxId     Int      @map("mailbox_id")
  domainId      Int      @map("domain_id")
  aliasLocalPart String  @map("alias_local_part") @db.VarChar(255)
  aliasAddress  String   @unique @map("alias_address") @db.VarChar(255)
  status        Status   @default(ACTIVE)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  domain  Domain        @relation(fields: [domainId], references: [id], onDelete: Cascade)
  mailbox DomainMailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@unique([domainId, aliasLocalPart])
  @@map("mailbox_aliases")
}

model IngressEndpoint {
  id             Int      @id @default(autoincrement())
  domainId       Int?     @map("domain_id")
  keyId          String   @unique @map("key_id") @db.VarChar(64)
  name           String   @db.VarChar(100)
  provider       String   @default("CLOUDFLARE_WORKER") @db.VarChar(50)
  signingKeyHash String?  @map("signing_key_hash") @db.VarChar(64)
  status         Status   @default(ACTIVE)
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  domain Domain? @relation(fields: [domainId], references: [id], onDelete: SetNull)

  @@map("ingress_endpoints")
}

model InboundMessage {
  id                BigInt               @id @default(autoincrement())
  domainId          Int                  @map("domain_id")
  mailboxId         Int?                 @map("mailbox_id")
  matchedAddress    String               @map("matched_address") @db.VarChar(255)
  finalAddress      String               @map("final_address") @db.VarChar(255)
  deliveryKey       String               @map("delivery_key") @db.VarChar(128)
  messageIdHeader   String?              @map("message_id_header") @db.VarChar(255)
  fromAddress       String               @map("from_address") @db.VarChar(255)
  toAddress         String               @map("to_address") @db.VarChar(255)
  subject           String?              @db.VarChar(500)
  textPreview       String?              @map("text_preview") @db.Text
  htmlPreview       String?              @map("html_preview") @db.Text
  verificationCode  String?              @map("verification_code") @db.VarChar(32)
  routeKind         String?              @map("route_kind") @db.VarChar(50)
  receivedAt        DateTime             @map("received_at")
  storageStatus     MessageStorageStatus @default(PENDING) @map("storage_status")
  rawObjectKey      String?              @map("raw_object_key") @db.VarChar(500)
  attachmentsMeta   Json?                @map("attachments_meta")
  headersJson       Json?                @map("headers_json")
  isRead            Boolean              @default(false) @map("is_read")
  isDeleted         Boolean              @default(false) @map("is_deleted")
  portalState       PortalState          @default(VISIBLE) @map("portal_state")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  domain     Domain             @relation(fields: [domainId], references: [id], onDelete: Cascade)
  mailbox    DomainMailbox?     @relation(fields: [mailboxId], references: [id], onDelete: SetNull)
  forwardJob MailboxForwardJob?

  @@unique([domainId, deliveryKey])
  @@index([domainId, receivedAt])
  @@index([mailboxId, receivedAt])
  @@map("inbound_messages")
}

model MailboxForwardJob {
  id                BigInt            @id @default(autoincrement())
  inboundMessageId  BigInt            @unique @map("inbound_message_id")
  mailboxId         Int?              @map("mailbox_id")
  mode              ForwardMode
  forwardTo         String            @map("forward_to") @db.VarChar(255)
  status            ForwardJobStatus  @default(PENDING)
  attemptCount      Int               @default(0) @map("attempt_count")
  lastError         String?           @map("last_error") @db.Text
  providerMessageId String?           @map("provider_message_id") @db.VarChar(255)
  nextAttemptAt     DateTime?         @default(now()) @map("next_attempt_at")
  processedAt       DateTime?         @map("processed_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  inboundMessage InboundMessage @relation(fields: [inboundMessageId], references: [id], onDelete: Cascade)
  mailbox        DomainMailbox? @relation(fields: [mailboxId], references: [id], onDelete: SetNull)

  @@index([status, nextAttemptAt, createdAt])
  @@index([mailboxId, status, nextAttemptAt])
  @@map("mailbox_forward_jobs")
}

model OutboundMessage {
  id                BigInt      @id @default(autoincrement())
  domainId          Int         @map("domain_id")
  mailboxId         Int?        @map("mailbox_id")
  providerMessageId String?     @map("provider_message_id") @db.VarChar(255)
  fromAddress       String      @map("from_address") @db.VarChar(255)
  toAddresses       Json        @map("to_addresses")
  subject           String?     @db.VarChar(500)
  htmlBody          String?     @map("html_body") @db.Text
  textBody          String?     @map("text_body") @db.Text
  status            SendStatus  @default(PENDING)
  lastError         String?     @map("last_error") @db.Text
  scheduledAt       DateTime?   @map("scheduled_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  domain  Domain         @relation(fields: [domainId], references: [id], onDelete: Cascade)
  mailbox DomainMailbox? @relation(fields: [mailboxId], references: [id], onDelete: SetNull)

  @@index([domainId, createdAt])
  @@map("outbound_messages")
}

// ============================================
// 枚举
// ============================================
enum Role {
  SUPER_ADMIN
  ADMIN
}

enum Status {
  ACTIVE
  DISABLED
}

enum DomainStatus {
  PENDING
  ACTIVE
  DISABLED
  ERROR
}

enum MailboxUserStatus {
  ACTIVE
  DISABLED
}

enum MailboxRole {
  OWNER
  MEMBER
  VIEWER
}

enum DomainMailboxStatus {
  ACTIVE
  DISABLED
  SUSPENDED
}

enum DomainMailboxProvisioningMode {
  MANUAL
  API_POOL
}

enum ForwardMode {
  DISABLED
  COPY
  MOVE
}

enum PortalState {
  VISIBLE
  FORWARDED_HIDDEN
}

enum ForwardJobStatus {
  PENDING
  RUNNING
  SENT
  FAILED
  SKIPPED
}

enum MessageStorageStatus {
  PENDING
  STORED
  FAILED
}

enum SendStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

enum EmailStatus {
  ACTIVE
  ERROR
  DISABLED
}

enum MailFetchStrategy {
  GRAPH_FIRST
  IMAP_FIRST
  GRAPH_ONLY
  IMAP_ONLY
}


enum MailProvider {
  OUTLOOK
  GMAIL
  QQ
  NETEASE_163
  NETEASE_126
  ICLOUD
  YAHOO
  ZOHO
  ALIYUN
  AMAZON_WORKMAIL
  FASTMAIL
  AOL
  GMX
  MAILCOM
  YANDEX
  CUSTOM_IMAP_SMTP
}

enum MailAuthType {
  MICROSOFT_OAUTH
  GOOGLE_OAUTH
  APP_PASSWORD
}

enum SendProvider {
  RESEND
}
