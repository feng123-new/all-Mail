# Advanced Docker template for Cloudflare ingress-ready deployments.
#
# Use this when you want to prepare the stack for Cloudflare Email Routing
# and signed ingress on first boot.

COMPOSE_PROJECT_NAME=all-mail
APP_PUBLISH_HOST=127.0.0.1
APP_PORT=3002
APP_INTERNAL_PORT=3000
REDIS_PUBLISH_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_INTERNAL_PORT=6379
POSTGRES_PUBLISH_HOST=127.0.0.1
POSTGRES_PORT=15433
POSTGRES_INTERNAL_PORT=5432
POSTGRES_USER=allmail
POSTGRES_PASSWORD=allmail_dev_password
POSTGRES_DB=allmail

# App bootstrap secrets (optional for first boot)
# Leave blank to auto-generate and persist on first startup.
# - JWT_SECRET: signs admin/mailbox-portal login tokens
# - ENCRYPTION_KEY: encrypts stored mailbox passwords, OAuth secrets, and refresh tokens
# - ADMIN_PASSWORD: bootstrap admin password for the first console login; auto-generated if blank
JWT_SECRET=
ENCRYPTION_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional public access URL used in first-boot login output.
# Set this to your cloud server public IP/domain when deploying remotely.
# Leave it blank only when local-only access is intended.
PUBLIC_BASE_URL=
ALL_MAIL_STATE_DIR=/var/lib/all-mail

# Base app settings
CORS_ORIGIN=
ALLOW_LOCAL_RATE_LIMIT_FALLBACK=false
JWT_EXPIRES_IN=2h
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCK_MINUTES=15
ADMIN_2FA_SECRET=
ADMIN_2FA_WINDOW=1
API_LOG_RETENTION_DAYS=30
API_LOG_CLEANUP_INTERVAL_MINUTES=60
FORWARDING_WORKER_INTERVAL_SECONDS=30
FORWARDING_WORKER_BATCH_SIZE=10
DOMAIN_BOOTSTRAP_ADMIN_USERNAME=
DOMAIN_BOOTSTRAP_ADMIN_PASSWORD=
SEND_ENABLED_DOMAINS=

# Optional provider OAuth (provider-side credentials you configure when enabling Gmail / Outlook flows)
# Replace 127.0.0.1 below with your cloud server public IP/domain or the correct local address.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:3002/admin/oauth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.modify https://mail.google.com/
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://127.0.0.1:3002/admin/oauth/outlook/callback
MICROSOFT_OAUTH_TENANT=consumers
MICROSOFT_OAUTH_SCOPES=offline_access openid profile email https://graph.microsoft.com/User.Read https://graph.microsoft.com/Mail.ReadWrite https://graph.microsoft.com/Mail.Send https://graph.microsoft.com/Contacts.ReadWrite https://graph.microsoft.com/Calendars.ReadWrite https://graph.microsoft.com/MailboxSettings.ReadWrite

# Advanced / Cloudflare ingress mode
# Replace this placeholder with a real shared secret on both the backend and worker side.
# It is not bootstrap-managed.
INGRESS_SIGNING_SECRET=replace-with-random-ingress-secret
INGRESS_ALLOWED_SKEW_SECONDS=300
