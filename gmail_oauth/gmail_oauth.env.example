# Preferred mode: point directly at Google Console's client_secret_*.json.
# The script will auto-read client_id / client_secret / redirect_uri from it.
GOOGLE_CLIENT_SECRET_JSON=/path/to/google-client-secret.json

# Optional manual override mode. Leave blank when GOOGLE_CLIENT_SECRET_JSON is set.
# JSON mapping example:
# - GOOGLE_CLIENT_ID     <- web.client_id
# - GOOGLE_CLIENT_SECRET <- web.client_secret
# - REDIRECT_URI         <- web.redirect_uris[0]
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REDIRECT_URI=
REDIRECT_HOST=127.0.0.1
REDIRECT_PORT=8766
REDIRECT_PATH=/callback
SCOPES=openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.modify https://mail.google.com/
MAILBOX=INBOX
ACCOUNT_EMAIL=

ADMIN_BASE_URL=http://127.0.0.1:3002
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-your-admin-password
TARGET_EMAIL_ID=
ALLOW_TARGET_ID_REPLACE=false
