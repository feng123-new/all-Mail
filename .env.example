COMPOSE_PROJECT_NAME=all-mail
APP_PORT=3002
APP_INTERNAL_PORT=3000
REDIS_PORT=6380
REDIS_INTERNAL_PORT=6379
POSTGRES_PORT=15433
POSTGRES_INTERNAL_PORT=5432
POSTGRES_USER=allmail
POSTGRES_PASSWORD=allmail_dev_password
POSTGRES_DB=allmail
JWT_SECRET=replace-with-at-least-32-char-random-secret
ENCRYPTION_KEY=replace-with-32-character-secret-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
DOMAIN_BOOTSTRAP_ADMIN_USERNAME=admin
DOMAIN_BOOTSTRAP_ADMIN_PASSWORD=
SEND_ENABLED_DOMAINS=
INGRESS_SIGNING_SECRET=
INGRESS_ALLOWED_SKEW_SECONDS=300
OBJECT_STORAGE_PROVIDER=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
RESEND_DEFAULT_FROM_NAME=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:3002/admin/oauth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.modify https://mail.google.com/
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://127.0.0.1:3002/admin/oauth/outlook/callback
MICROSOFT_OAUTH_TENANT=consumers
MICROSOFT_OAUTH_SCOPES=offline_access openid profile email https://graph.microsoft.com/User.Read https://graph.microsoft.com/Mail.ReadWrite https://graph.microsoft.com/Mail.Send https://graph.microsoft.com/Contacts.ReadWrite https://graph.microsoft.com/Calendars.ReadWrite https://graph.microsoft.com/MailboxSettings.ReadWrite
